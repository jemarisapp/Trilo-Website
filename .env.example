# Copy this file to .env and fill in your API key
# Restart the dev server after adding it

# OpenAI API key — required for the "Scan Bracket Image" feature on the CFP Bracket page
# Server-side only — never use VITE_ prefix for secrets
OPENAI_API_KEY=your-openai-api-key-here

# Site URLs and Discord OAuth
VITE_SITE_URL=http://localhost:3000
VITE_DISCORD_CLIENT_ID=your-discord-client-id
DISCORD_CLIENT_ID=your-discord-client-id
DISCORD_CLIENT_SECRET=your-discord-client-secret
DISCORD_REDIRECT_URI=http://localhost:3000/auth/callback
DISCORD_TOKEN=your-discord-bot-token

# Stripe
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_ID_MONTHLY=price_xxx
STRIPE_PRICE_ID_ANNUAL=price_xxx
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
VITE_STRIPE_PRICE_ID_MONTHLY=price_xxx
VITE_STRIPE_PRICE_ID_ANNUAL=price_xxx

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key
